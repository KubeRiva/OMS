# =============================================================================
# OMS Environment Configuration
# Copy this file to .env for local development.
# In Kubernetes, inject these as environment variables — do NOT mount .env.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Tenant identity — injected by K8s Deployment per pod
# ---------------------------------------------------------------------------
TENANT_SLUG=acme                        # Unique org slug (e.g. acme, widgetco)
ENVIRONMENT=development                 # development | staging | production
PLAN_TIER=STARTER                       # STARTER | GROWTH | PRO | ENTERPRISE

# ---------------------------------------------------------------------------
# PostgreSQL (DigitalOcean Managed Postgres recommended)
# One database per tenant-environment pod.
# Generate password: openssl rand -hex 16
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://oms_user:YOUR_POSTGRES_PASSWORD@postgres:5432/oms_db
SYNC_DATABASE_URL=postgresql+psycopg2://oms_user:YOUR_POSTGRES_PASSWORD@postgres:5432/oms_db

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGODB_URL=mongodb://oms_user:YOUR_MONGODB_PASSWORD@mongodb:27017/oms_events?authSource=admin
MONGODB_DB=oms_events
MONGODB_AI_DB=oms_ai_learning

# ---------------------------------------------------------------------------
# Redis
# Leave CELERY_BROKER_URL / CELERY_RESULT_BACKEND blank to auto-derive from REDIS_URL
# ---------------------------------------------------------------------------
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ELASTICSEARCH_URL=http://elasticsearch:9200

# ---------------------------------------------------------------------------
# Application secrets
# Generate: openssl rand -hex 32
# These are validated at startup in production — the app will refuse to start
# if these still contain the default values.
# ---------------------------------------------------------------------------
SECRET_KEY=your-64-character-random-secret-key-generated-with-openssl-rand-hex-32
API_KEY=your-32-character-random-api-key
WEBHOOK_SECRET=your-32-character-random-webhook-secret
TEST_API_KEY=dev-test-key-change-in-production

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:8001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ---------------------------------------------------------------------------
# DigitalOcean Spaces (object storage)
# Create a Space at https://cloud.digitalocean.com/spaces
# Leave blank to disable file storage features.
# ---------------------------------------------------------------------------
SPACES_BUCKET=oms-assets
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_KEY=YOUR_DO_SPACES_ACCESS_KEY
SPACES_SECRET=YOUR_DO_SPACES_SECRET_KEY

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Sourcing
# ---------------------------------------------------------------------------
DEFAULT_SOURCING_STRATEGY=DISTANCE_OPTIMAL
MAX_SPLIT_NODES=3

# ---------------------------------------------------------------------------
# Backorder retry
# ---------------------------------------------------------------------------
BACKORDER_RETRY_INTERVAL_MINUTES=30
BACKORDER_MAX_AGE_HOURS=72

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Anthropic (AI sourcing advisor)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Kubernetes Deployment Checklist
# =============================================================================
# 1. Set TENANT_SLUG, ENVIRONMENT, PLAN_TIER per pod via K8s env or ConfigMap
# 2. Inject DATABASE_URL pointing at this tenant's dedicated database
# 3. Set MONGODB_DB / MONGODB_AI_DB with tenant-scoped names (e.g. oms_events_acme_prod)
# 4. Generate strong secrets (openssl rand -hex 32) — never reuse dev values
# 5. Set ENVIRONMENT=production — app validates secrets at startup and refuses insecure defaults
# 6. Configure SPACES_* for tenant-scoped object storage
# 7. Set ALLOWED_ORIGINS to the tenant's actual frontend URL
# =============================================================================
